@echo off
:: 强制使用 UTF-8 编码，防止终端里的中文乱码
chcp 65001 >nul

echo ==========================================
echo   正在启动 Vibe Coder 专属视觉引擎...
echo ==========================================

:: 魔法指针：%~dp0 会自动获取当前 .bat 文件所在的绝对目录
cd /d "%~dp0"

:: 核心降维打击：通过 -- 将 --open 参数直接透传给底层的 Vite
:: 这样你连 package.json 都不用改了！
npm run dev -- --open

pause